PORT=5000
DB_DRIVER=sqlite
DB_FILE=./data/skillbridge.sqlite
# To use MySQL instead, set DB_DRIVER=mysql and update the following values:
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=root
# DB_NAME=skillbridge_db
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=1d
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
