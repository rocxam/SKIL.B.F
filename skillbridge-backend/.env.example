PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@host:5432/skillbridge_db
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET_MATERIALS=materials
SUPABASE_STORAGE_BUCKET_SUBMISSIONS=submissions
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=1d
# In local development, set the frontend origin used by Vite and other dev servers.
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
